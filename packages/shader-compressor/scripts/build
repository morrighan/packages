#!/usr/bin/env bash

function bootstrap() {
    unset -f bootstrap

    if ! test "$(command -v emsdk)"; then
        cd artifacts/emsdk || exit 1

        EMSDK_QUIET=1 \
        source ./emsdk_env.sh > /dev/null

        cd ../..
    fi

    emcmake \
    cmake -S . -B dists -G Ninja

    cmake --build dists
}

bootstrap "$@"
