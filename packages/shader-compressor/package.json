{
    "name": "@cichol/shader-compressor",
    "version": "5.3.0",
    "description": "A compressor for WebGL2 shader source code. (GLSL ES 3.00)",
    "homepage": "https://github.com/morrighan/packages",
    "bugs": {
        "url": "https://github.com/morrighan/packages/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Yongbin Min",
        "email": "contact@cichol.com",
        "url": "https://www.cichol.com/"
    },
    "type": "module",
    "main": "./dists/index.cjs",
    "module": "./dists/index.js",
    "types": "./dists/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "default": "./dists/index.js",
                "types": "./dists/index.d.ts"
            },
            "require": {
                "default": "./dists/index.cjs",
                "types": "./dists/index.d.cts"
            }
        },
        "./package.json": "./package.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/morrighan/packages.git",
        "directory": "packages/shader-compressor"
    },
    "scripts": {
        "build": "bash scripts/build"
    },
    "dependencies": {},
    "engines": {
        "node": "^20.19.5 || ^22.20.0",
        "npm": "^11.6.1"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    }
}
