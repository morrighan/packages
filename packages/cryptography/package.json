{
    "name": "@cichol/cryptography",
    "version": "6.1.3",
    "description": "A cryptography library providing various IES presets based on Web Crypto API for personal projects.",
    "homepage": "https://github.com/morrighan/packages",
    "bugs": {
        "url": "https://github.com/morrighan/packages/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Yongbin Min",
        "email": "contact@cichol.com",
        "url": "https://www.cichol.com/"
    },
    "type": "module",
    "exports": {
        ".": {
            "default": "./dists/index.js",
            "types": "./dists/index.d.ts"
        },
        "./*": {
            "default": "./dists/presets/*.js",
            "types": "./dists/presets/*.d.ts"
        },
        "./package.json": "./package.json"
    },
    "imports": {
        "#*": "./sources/*.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/morrighan/packages.git",
        "directory": "packages/cryptography"
    },
    "dependencies": {
        "@babel/runtime-corejs3": "^7.29.2",
        "@msgpack/msgpack": "^3.1.3",
        "@std/assert": "npm:@jsr/std__assert@^1.0.19",
        "@std/encoding": "npm:@jsr/std__encoding@^1.0.10",
        "core-js-pure": "^3.49.0"
    },
    "engines": {
        "node": "^24.15.0",
        "npm": "^11.12.1"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    }
}
